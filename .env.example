# ==================== 环境变量配置模板 ====================
# 复制此文件为 .env 并填入你的真实凭据
#   cp .env.example .env
#
# Docker Compose 会自动加载同级目录下的 .env 文件。
# ===========================================================

# -------- Database --------
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_PASSWORD=change-me-user-password

# -------- AI API Keys --------
# 阿里百炼 DashScope: https://dashscope.console.aliyun.com/apiKey
SPRING_AI_DASHSCOPE_API_KEY=sk-your-dashscope-api-key
# OpenAI 兼容端点（百炼代理）: 同上
SPRING_AI_OPENAI_API_KEY=sk-your-dashscope-api-key
# LangChain4j 应用层
APP_AI_API_KEY=sk-your-dashscope-api-key

# -------- JWT --------
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# -------- 七牛云对象存储 --------
# 七牛云控制台: https://portal.qiniu.com/
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET=your-bucket-name
QINIU_DOMAIN=http://your-domain.clouddn.com

# -------- TTS 语音合成 --------
# 小米 MiMo TTS: https://api.xiaomimimo.com
MIMO_API_KEY=sk-your-mimo-api-key
